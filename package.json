{
  "name": "codex-pro-max-next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,ui -c cyan,magenta \"tsx watch src/index.ts\" \"node scripts/wait-for-api.mjs && vite --host 127.0.0.1 --port 53128\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:ui": "vite --host 127.0.0.1 --port 53128",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:ui": "vite build",
    "test": "vitest run -c vitest.config.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "katex": "^0.16.47",
    "multer": "^2.1.1",
    "photoswipe": "^5.4.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
